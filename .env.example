# =============================================================================
#  TradePilot – Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  This file is safe to commit to GitHub (no real secrets here).
# =============================================================================

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Get both URLs from: Supabase → Project Settings → Database → Connection string
# Pooled connection (used at runtime via pgBouncer – port 6543)
DATABASE_URL="postgres://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
# Direct connection (used by Prisma Migrate – port 5432)
DATABASE_URL_DIRECT="postgres://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ── Funnel Session ────────────────────────────────────────────────────────────
# Key name used for the localStorage / cookie funnel session (keep as-is)
NEXT_PUBLIC_FUNNEL_SESSION_KEY="funnel_session_v1"

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Login credentials for /admin
ADMIN_USER="admin@yourdomain.com"
ADMIN_PASS="ChangeMe-Strong-Password-Here!"
# JWT signing secret (generate with: openssl rand -base64 48)
ADMIN_TOKEN="replace-with-random-64-char-string"
# One-click magic login – access via /api/admin/magic?key=<value>
# Generate with: openssl rand -base64 48
ADMIN_MAGIC_KEY="replace-with-random-64-char-string"

# ── Security ──────────────────────────────────────────────────────────────────
# Salt for hashing visitor IPs in rate-limit records (generate with: openssl rand -base64 32)
IP_HASH_SALT="replace-with-random-32-char-string"
# Secret used to verify postback calls from your CPA network
POSTBACK_SECRET="replace-with-random-40-char-string"

# ── CPA & Conversion ──────────────────────────────────────────────────────────
# CRITICAL – broker registration page. Users are redirected here after the lead form.
# Example: https://register.broker.com/?aff=1234&s1=tradepilot
NEXT_PUBLIC_CPA_OFFER_URL=""

# Minimum funnel engagement score required before marking a conversion (0 = allow all)
CONVERT_MIN_SCORE="0"

# Server-to-server postback URL template from your CPA network
# Replace click-id placeholder with {txid}
# Example: https://track.network.com/postback?clickid={txid}&status=lead&payout=auto
CPA_POSTBACK_URL_TEMPLATE=""

# ── Traffic Gate ──────────────────────────────────────────────────────────────
# Private token appended to your ad links: /?utm_source=<token>
# Keeps competitors from viewing your funnel directly.
# Leave blank to allow all traffic without token verification.
UTM_SOURCE_TOKEN=""

# Comma-separated CIDR ranges always allowed through the ad gate
# Use for your office / review team IPs. Example: "203.0.113.0/24,198.51.100.5/32"
EDUCATION_IP_RANGES=""

# ── CRM Integration ───────────────────────────────────────────────────────────
# Set CRM_ENABLED=true to push leads to your CRM after form submission
CRM_ENABLED="false"
CRM_URL=""
CRM_API_KEY=""
# How to authenticate: bearer | x-api-key | none
CRM_AUTH_MODE="bearer"
# Timeout for CRM requests in milliseconds
CRM_TIMEOUT_MS="8000"
# Secret for verifying inbound CRM webhook calls to /api/webhook/crm
CRM_WEBHOOK_KEY=""

# ── Market Data (optional) ────────────────────────────────────────────────────
# Powers the live candle chart inside the funnel.
# Both providers have a free tier – only one is needed.
# Twelve Data: https://twelvedata.com/apikey
TWELVE_DATA_API_KEY=""
# Finnhub: https://finnhub.io/dashboard
FINNHUB_API_KEY=""
